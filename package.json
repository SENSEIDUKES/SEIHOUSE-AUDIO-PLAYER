{
  "name": "@seihouse/audio-player",
  "version": "1.0.0",
  "description": "Portable custom audio player (React + TypeScript) — zero-dependency core with optional lazy-loaded Automix beat analysis and wavesurfer.js waveforms",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "build:lib": "vite build --config vite.lib.config.ts",
    "prepare": "npm run build:lib",
    "prepublishOnly": "npm run typecheck && npm run build:lib",
    "preview": "vite preview --host 0.0.0.0",
    "preview:smoke": "node scripts/preview-smoke-test.mjs",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test": "npm run typecheck && npm run test:unit && npm run build && npm run preview:smoke",
    "skin:import": "node scripts/import-skin.mjs"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.58.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/react-virtualized-auto-sizer": "^1.0.4",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.8"
  },
  "license": "UNLICENSED",
  "dependencies": {
    "essentia.js": "0.1.3",
    "react-virtualized-auto-sizer": "^2.0.3",
    "react-window": "^1.8.10",
    "wavesurfer.js": "^7.12.7",
    "zod": "^4.4.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SEIHouse/audio-player.git"
  },
  "keywords": [
    "audio",
    "player",
    "react",
    "typescript",
    "music",
    "web-audio",
    "automix"
  ],
  "author": "SEIHouse"
}
